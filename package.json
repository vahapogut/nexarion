{
  "name": "nexarion",
  "version": "0.6.0",
  "private": true,
  "description": "Universal MCP ↔ A2A Bridge — connect any MCP client to any A2A agent",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "eslint packages/*/src/**/*.ts",
    "format": "prettier --write packages/*/src/**/*.ts",
    "dev": "pnpm --filter nexarion-server dev",
    "prepare": "husky"
  },
  "keywords": [
    "mcp",
    "a2a",
    "bridge",
    "agent",
    "protocol",
    "model-context-protocol",
    "agent-to-agent",
    "interoperability"
  ],
  "engines": {
    "node": ">=20"
  },
  "author": "Abdulvahap OGUT <info@ipeclabs.com>",
  "license": "Apache-2.0",
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/node": "^25.8.0",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "eslint": "^10.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.3"
  }
}
