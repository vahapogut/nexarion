{
  "name": "nexarioncli",
  "version": "0.5.0",
  "engines": { "node": ">=20" },
  "description": "Nexarion CLI — manage the MCP ↔ A2A bridge",
  "bin": { "nexarion": "./dist/cli.js" },
  "type": "module",
  "exports": { ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js", "require": "./dist/index.cjs" } },
  "scripts": {
    "build": "tsup src/cli.ts --format esm",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "nexarion-core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "files": ["dist"],
  "license": "Apache-2.0",
  "repository": { "type": "git", "url": "https://github.com/vahapogut/nexarion" },
