{
  "name": "nexarion-server",
  "version": "0.6.0",
  "engines": { "node": ">=20" },
  "description": "Nexarion MCP Server — exposes A2A agents as MCP tools via stdio or HTTP",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "bin": {
    "nexarion-server": "./dist/cli.js"
  },
  "exports": { ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js", "require": "./dist/index.cjs" } },
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts --format esm,cjs --dts",
    "test": "vitest run --passWithNoTests",
    "dev": "tsx src/cli.ts"
  },
  "dependencies": {
    "nexarion-core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "tsup": "^8.0.0",
    "tsx": "^4.10.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "files": [
    "dist"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/vahapogut/nexarion"
  },
  "keywords": [
    "mcp",
    "a2a",
    "nexarion",
    "server",
    "bridge"
  ],
  "author": "Abdulvahap OGUT <info@ipeclabs.com>"
}
