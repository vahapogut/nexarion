# Nexarion — Environment Variables

# Comma-separated A2A agent URLs for auto-discovery
NEXARION_AGENTS=https://agent1.example.com,https://agent2.example.com

# A2A agent auth token (passed to agents via Authorization header)
A2A_AUTH_TOKEN=

# MCP auth token
MCP_AUTH_TOKEN=

# Server transport: stdio (Claude Desktop) or http (remote deployment)
NEXARION_TRANSPORT=stdio

# HTTP server port (only for http transport)
PORT=3000

# Path to nexarion config file
NEXARION_CONFIG=./nexarion.config.json

# Log level: debug | info | warn | error
LOG_LEVEL=info

# OpenTelemetry endpoint (optional)
OTEL_EXPORTER_OTLP_ENDPOINT=
